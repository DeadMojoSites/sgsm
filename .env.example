# Steam Game Server Manager — Environment Variables
# Copy this file to .env and fill in your values before running docker-compose up

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key used to encrypt Steam credentials stored in the database.
# Generate a strong random value: openssl rand -hex 32
APP_KEY=changeme-please-set-a-32-char-secret

# ── Docker / Paths (usually auto-detected, override only if needed) ───────────

# Absolute host path to the gsm_servers directory.
# Docker containers use this to bind-mount game server files.
# Defaults to $PWD/gsm_servers in docker-compose.yml.
# GSM_SERVERS_HOST_PATH=/absolute/path/to/gsm_servers

# ── Optional: override with explicit UID/GID if you have permission issues ───
# PUID=1000
# PGID=1000
